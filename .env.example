# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paynecta Configuration
# Use the Paynecta URL for your MetaOrbit campaign
NEXT_PUBLIC_PAYNECTA_URL=https://paynecta.co.ke/pay/metaorbit
PAYNECTA_WEBHOOK_SECRET=your_paynecta_webhook_secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
